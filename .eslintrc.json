{
  "env": {
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-constant-condition": "warn",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-prototype-builtins": "off",
    "no-redeclare": "warn",
    "no-undef": "error",
    "no-unreachable": "warn",
    "no-unsafe-finally": "error",
    "no-unsafe-negation": "error",
    "eqeqeq": ["warn", "smart"],
    "no-caller": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-throw-literal": "warn",
    "no-with": "error",
    "prefer-const": ["warn", { "destructuring": "all" }],
    "no-var": "warn"
  },
  "overrides": [
    {
      "files": ["renderer/**/*.js"],
      "env": {
        "node": false,
        "browser": true,
        "commonjs": true
      },
      "globals": {
        "ipcRenderer": "readonly",
        "AnimationSystem": "readonly",
        "BubbleComponent": "readonly",
        "StatusBarComponent": "readonly",
        "ModalComponent": "readonly",
        "PanelCommon": "readonly",
        "PetEngineModule": "readonly",
        "backendReady": "writable",
        "confirmBtn": "writable"
      }
    },
    {
      "files": ["test/**/*.js"],
      "env": {
        "node": true
      },
      "rules": {
        "no-undef": "off"
      }
    }
  ],
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    "migrations/",
    "locales/",
    "*.min.js"
  ]
}
